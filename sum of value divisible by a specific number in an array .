import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
       Scanner sc=new Scanner(System.in);
       int n=sc.nextInt();
       int arr[]=new int[n];
       for(int i=0;i<n;i++) {arr[i]=sc.nextInt();}
       int c=0;
              int div=sc.nextInt();
int temp=0;
 System.out.print("The elements that are divisible by "+div+" is");

       for(int i=0;i<n;i++){
        if((arr[i]%div)==0){
            System.out.print(" "+arr[i]);
            temp+=arr[i];
          c++;
        }    
       }                System.out.println();
     
     System.out.println("The Count of the value that is divisible by "+div+" is "+c);
 System.out.print("The Sum of value that is divisible by "+div+" is "+temp);
    } 
    }
